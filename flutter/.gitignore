# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
# Ignore native build artifacts but keep the web build so GitHub Pages can serve it
/build/android/
/build/app/
/build/ios/
/build/linux/
/build/macos/
/build/windows/
/build/flutter_assets/
/build/.cxx/
/build/native_hooks/
/build/reports/
/build/*_android/
/build/*.dill*
/build/*.bin
/build/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]*/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
